# Production Docker environment — copy to .env.docker on the Nayatel VM:
#   cp .env.docker.production.example .env.docker
#
# Used by: docker compose -f docker-compose.prod.yml --env-file .env.docker

# ── Public URL (scheme + host, no trailing slash) ───────────────────────────
# Must match what users type in the browser. Used for CORS + password-reset links.
# Examples:
#   PUBLIC_ORIGIN=http://203.0.113.10
#   PUBLIC_ORIGIN=https://mrv.prmsc.gov.pk
PUBLIC_ORIGIN=https://mrv.example.com

PASSWORD_RESET_FRONTEND_URL=https://mrv.example.com/reset-password

# ── PostgreSQL (internal Docker network only) ─────────────────────────────────
POSTGRES_USER=prmsc
POSTGRES_PASSWORD=change-me-use-openssl-rand-hex-32
POSTGRES_DB=prmsc_mrv

# ── Backend secrets (openssl rand -hex 32) ──────────────────────────────────
SECRET_KEY=change-me-use-openssl-rand-hex-32
JWT_SECRET_KEY=change-me-use-openssl-rand-hex-32

# ── Edge nginx ports on the VM ──────────────────────────────────────────────
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# ── Optional SMTP (password reset emails) ─────────────────────────────────────
# MAIL_SERVER=smtp.example.com
# MAIL_PORT=587
# MAIL_USE_TLS=true
# MAIL_USERNAME=
# MAIL_PASSWORD=
# MAIL_DEFAULT_SENDER=noreply@mrv.example.com

# ── File uploads (S3-compatible — keep Supabase storage during cutover) ─────
# SUPABASE_STORAGE_BUCKET=mrv-public
# SUPABASE_S3_ENDPOINT=https://YOUR_PROJECT.storage.supabase.co/storage/v1/s3
# SUPABASE_S3_REGION=ap-northeast-1
# SUPABASE_S3_ACCESS_KEY_ID=
# SUPABASE_S3_SECRET_ACCESS_KEY=
# SUPABASE_STORAGE_PUBLIC_BASE_URL=https://YOUR_PROJECT.supabase.co/storage/v1/object/public
