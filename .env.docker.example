POSTGRES_DB=prmsc_mrv
POSTGRES_PORT=5433

BACKEND_PORT=5001

SECRET_KEY=change-me-in-production
JWT_SECRET_KEY=change-me-in-production

CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://prmsc-mrv-app.vercel.app

