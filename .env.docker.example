# Copy to .env.docker at repo root:
#   cp .env.docker.example .env.docker          # local dev (postgres + backend only)
#   cp .env.docker.production.example .env.docker  # Nayatel VM full stack

POSTGRES_USER=prmsc
POSTGRES_PASSWORD=prmsc
POSTGRES_DB=prmsc_mrv
POSTGRES_PORT=5433

BACKEND_PORT=5001

SECRET_KEY=change-me-in-production
JWT_SECRET_KEY=change-me-in-production

# Local dev only — production uses PUBLIC_ORIGIN in .env.docker.production.example
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://prmsc-mrv-app.vercel.app

# Production full stack: see .env.docker.production.example and deploy/README.md

# Optional: file uploads (S3-compatible storage). Leave empty if uploads are not used yet.
# SUPABASE_STORAGE_BUCKET=
# SUPABASE_S3_ENDPOINT=
# SUPABASE_S3_REGION=
# SUPABASE_S3_ACCESS_KEY_ID=
# SUPABASE_S3_SECRET_ACCESS_KEY=
# SUPABASE_STORAGE_PUBLIC_BASE_URL=
