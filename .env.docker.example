# PRMSC-MRV Docker environment
# Setup copies this automatically:  ./deploy/setup.sh
# Or manually:  cp .env.docker.example .env.docker

# Public URL users open in the browser (no trailing slash).
# VM example: http://101.50.86.169
PUBLIC_ORIGIN=CHANGE_ME

# Database (local Docker Postgres — not Supabase)
POSTGRES_USER=prmsc
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=prmsc_mrv

# App secrets (setup.sh generates these if still CHANGE_ME)
SECRET_KEY=CHANGE_ME
JWT_SECRET_KEY=CHANGE_ME

# Web entry port on the server
NGINX_HTTP_PORT=80

# Optional: password-reset email link base (defaults to PUBLIC_ORIGIN/reset-password)
# PASSWORD_RESET_FRONTEND_URL=

# Supabase Storage only (S3-compatible API) — database runs in Docker Postgres above
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_STORAGE_BUCKET=mrv-public
SUPABASE_S3_ENDPOINT=https://YOUR_PROJECT.storage.supabase.co/storage/v1/s3
SUPABASE_S3_REGION=ap-northeast-1
SUPABASE_S3_ACCESS_KEY_ID=
SUPABASE_S3_SECRET_ACCESS_KEY=
# Optional — auto-derived from SUPABASE_URL when unset:
# SUPABASE_STORAGE_PUBLIC_BASE_URL=https://YOUR_PROJECT.supabase.co/storage/v1/object/public

# Optional: SMTP for password-reset emails
# MAIL_SERVER=
# MAIL_PORT=587
# MAIL_USE_TLS=true
# MAIL_USERNAME=
# MAIL_PASSWORD=
# MAIL_DEFAULT_SENDER=

# Local laptop only — expose Postgres/API when running: docker compose up postgres backend -d
POSTGRES_PORT=5433
BACKEND_PORT=5001
