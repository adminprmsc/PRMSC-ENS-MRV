#
# Production — used automatically for release builds (assembleRelease / Archive).
# Android: android/app/build.gradle → envConfigFiles.release
# iOS: set ENVFILE=.env.production when building Release (see package.json ios:release).
#
# API URL is hardcoded in src/config/env.ts (PROD_API_URL); do not add API_URL here.
#
ENV=PROD
