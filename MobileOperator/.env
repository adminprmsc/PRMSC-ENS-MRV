#
# Local development env (debug builds). Release APKs use `.env.production`.
#
# - ENV=DEV  → http://127.0.0.1:5001/api
# - ENV=PROD → http://101.50.86.169/api (VM — same as release)
#
ENV=DEV
#
# Optional override (host-only is OK; `/api` is auto-appended if missing):
# API_URL=http://127.0.0.1:5001
# API_URL=http://101.50.86.169/api
