#
# Environment switch (local development — used by debug builds):
#
# - ENV=DEV  → API URL defaults to `http://127.0.0.1:5001/api`
# - ENV=PROD → API URL defaults to `http://101.50.86.169/api` (production VM)
#
# Release APKs (`assembleRelease`) always use `.env.production` instead of this file.
#
# Copy to `.env` for local dev:
#   cp env.example .env
#
ENV=DEV
# ENV=PROD
#
# Optional override (host-only is OK; `/api` is auto-appended if missing):
# API_URL=http://127.0.0.1:5001
# API_URL=http://101.50.86.169/api
