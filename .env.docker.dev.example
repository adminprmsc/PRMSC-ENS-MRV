# Local laptop — use BOTH compose files so API is on :5001 and CORS allows Vite:
#   cp .env.docker.dev.example .env.docker
#   docker compose -f docker-compose.yml -f docker-compose.dev.yml --env-file .env.docker up -d --build postgres backend
#   cd frontend && npm run dev
#
# Do NOT use only `docker compose --env-file .env.docker up -d backend` for local
# frontend dev — port 5001 will not be exposed to the host.