# Local development — copy to .env and fill values.

NODE_ENV=development
PORT=5001

SECRET_KEY=change-me
JWT_SECRET_KEY=change-me-too

# PostgreSQL (local or Docker). For docker-compose postgres service:
# DATABASE_URL=postgresql://prmsc:prmsc@127.0.0.1:5433/prmsc_mrv?sslmode=disable
DATABASE_URL=postgresql://prmsc:prmsc@127.0.0.1:5433/prmsc_mrv?sslmode=disable

# Optional: S3-compatible object storage for file uploads (can use MinIO or any S3 API).
# SUPABASE_STORAGE_BUCKET=mrv-public
# SUPABASE_S3_ENDPOINT=http://127.0.0.1:9000
# SUPABASE_S3_REGION=us-east-1
# SUPABASE_S3_ACCESS_KEY_ID=your-access-key-id
# SUPABASE_S3_SECRET_ACCESS_KEY=your-secret-access-key
# SUPABASE_STORAGE_PUBLIC_BASE_URL=http://127.0.0.1:9000/mrv-public

# Comma-separated frontend origins (scheme + host + port, no trailing slash).
# In development, local defaults (:5173, :5174, etc.) are merged automatically.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174

# Remote PostgreSQL with SSL (set sslmode=require in DATABASE_URL)
# DATABASE_SSL_REJECT_UNAUTHORIZED=false

# Optional SMTP for password reset emails
# MAIL_SERVER=smtp.example.com
# MAIL_PORT=587
# MAIL_USE_TLS=true
# MAIL_USERNAME=
# MAIL_PASSWORD=
# MAIL_DEFAULT_SENDER=
# PASSWORD_RESET_FRONTEND_URL=http://localhost:5173/reset-password

# When NODE_ENV=development, may return reset_token in forgot-password JSON response
# PASSWORD_RESET_DEV_RETURN_TOKEN=true
