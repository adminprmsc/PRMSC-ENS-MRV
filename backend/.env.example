# Local development — copy to .env and fill values.

NODE_ENV=development
PORT=5001

SECRET_KEY=change-me
JWT_SECRET_KEY=change-me-too

# Supabase pooler (recommended). If local DNS fails with "could not translate host name",
# the app resolves via 8.8.8.8 automatically. Or set DATABASE_HOST_IP to the pooler IP.
DATABASE_URL=postgresql://postgres.PROJECT_REF:YOUR_PASSWORD@aws-1-ap-northeast-1.pooler.supabase.com:5432/postgres

SUPABASE_URL=https://hyadnyrczyftkgdqyjhr.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here
SUPABASE_PROJECT_ID=hyadnyrczyftkgdqyjhr
SUPABASE_STORAGE_BUCKET=mrv-public
SUPABASE_S3_ENDPOINT=https://hyadnyrczyftkgdqyjhr.storage.supabase.co/storage/v1/s3
SUPABASE_S3_REGION=ap-northeast-1
SUPABASE_S3_ACCESS_KEY_ID=your-access-key-id
SUPABASE_S3_SECRET_ACCESS_KEY=your-secret-access-key

# Comma-separated frontend origins (scheme + host + port, no trailing slash).
# In development, local defaults (:5173, :5174, etc.) are merged automatically.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174

# Supabase SSL: node-postgres needs this unless you install Supabase's CA bundle.
# Set to true only if DATABASE_SSL_REJECT_UNAUTHORIZED is configured with a trusted CA.
# DATABASE_SSL_REJECT_UNAUTHORIZED=false

# Optional SMTP for password reset emails
# MAIL_SERVER=smtp.example.com
# MAIL_PORT=587
# MAIL_USE_TLS=true
# MAIL_USERNAME=
# MAIL_PASSWORD=
# MAIL_DEFAULT_SENDER=
# PASSWORD_RESET_FRONTEND_URL=http://localhost:5173/reset-password

# When NODE_ENV=development, may return reset_token in forgot-password JSON response
# PASSWORD_RESET_DEV_RETURN_TOKEN=true
