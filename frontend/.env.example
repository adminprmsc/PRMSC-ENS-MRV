# Copy to `.env` for local development (Vite reads `VITE_*` at build time).

# Environment switch:
# - VITE_ENV=DEV  → defaults to http://127.0.0.1:5001/api
# - VITE_ENV=PROD → defaults to /api (same-origin; used with Nayatel nginx proxy)
VITE_ENV=DEV

# Base URL for JSON API. The app appends `/api` when missing.
# Local dev:
#   VITE_API_URL=http://127.0.0.1:5001
# Docker production (built in frontend/Dockerfile):
#   VITE_API_URL=/api
# Optional override:
VITE_API_URL=

# HQ map uses OpenStreetMap (no API key).
